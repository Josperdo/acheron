# Copy to .env and fill in for live-tenant mode. Never commit the real .env file.

# "fixture" (default) loads fixtures/synthetic_tenant.json — no Azure credentials needed.
# "live" ingests from Microsoft Graph using the app registration below.
INGESTION_MODE=fixture

# Entra ID app registration (read-only Graph scopes ONLY — see Security.md):
#   Directory.Read.All, RoleManagement.Read.Directory, Application.Read.All, Group.Read.All
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# CORS: local frontend origin only
FRONTEND_ORIGIN=http://localhost:5173
